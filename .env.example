# Anthropic API Key
# https://console.anthropic.com/ で取得
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 送信元 Gmail アドレス
GMAIL_ADDRESS=your_gmail_address@gmail.com

# Gmail アプリパスワード（Googleアカウント → セキュリティ → 2段階認証 → アプリパスワード）
GMAIL_APP_PASSWORD=your_app_password_here

# 通知先メールアドレス
NOTIFY_EMAIL=your_notify_email@example.com
